<svg width="256" height="256" viewBox="0 0 256 256" fill="none" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <linearGradient id="logoGradient" x1="20" y1="128" x2="236" y2="128" gradientUnits="userSpaceOnUse">
      <stop offset="0" stop-color="#2D89FF"/>
      <stop offset="0.5" stop-color="#5E17EB"/>
      <stop offset="1" stop-color="#F25C48"/>
    </linearGradient>
  </defs>

  <!-- Centered container -->
  <g transform="translate(128, 128)">
    
    <!-- Left Mask (Happy) - Slightly behind -->
    <g transform="translate(-42, -5) rotate(-10)">
      <!-- Mask Body -->
      <path d="M-55 -35 C-55 -70 -20 -80 0 -70 C20 -80 55 -70 55 -35 C55 15 40 65 0 80 C-40 65 -55 15 -55 -35 Z" fill="white" stroke="url(#logoGradient)" stroke-width="12" stroke-linejoin="round"/>
      <!-- Happy Face -->
      <!-- Eyes -->
      <path d="M-28 -12 C-23 -25 -7 -25 -2 -12" stroke="#1A1A1A" stroke-width="12" stroke-linecap="round" fill="none"/>
      <path d="M12 -12 C17 -25 33 -25 38 -12" stroke="#1A1A1A" stroke-width="12" stroke-linecap="round" fill="none"/>
      <!-- Mouth -->
      <path d="M-22 35 C-12 50 12 50 22 35" stroke="#1A1A1A" stroke-width="12" stroke-linecap="round" fill="none"/>
    </g>

    <!-- Right Mask (Tragedy) - In front -->
    <g transform="translate(42, 5) rotate(10)">
      <!-- Mask Body -->
      <path d="M-55 -35 C-55 -70 -20 -80 0 -70 C20 -80 55 -70 55 -35 C55 15 40 65 0 80 C-40 65 -55 15 -55 -35 Z" fill="white" stroke="url(#logoGradient)" stroke-width="12" stroke-linejoin="round"/>
      <!-- Sad Face -->
      <!-- Eyes -->
      <path d="M-28 0 C-23 13 -7 13 -2 0" stroke="#1A1A1A" stroke-width="12" stroke-linecap="round" fill="none"/>
      <path d="M12 0 C17 13 33 13 38 0" stroke="#1A1A1A" stroke-width="12" stroke-linecap="round" fill="none"/>
      <!-- Mouth -->
      <path d="M-22 55 C-12 40 12 40 22 55" stroke="#1A1A1A" stroke-width="12" stroke-linecap="round" fill="none"/>
    </g>
    
  </g>
</svg>
